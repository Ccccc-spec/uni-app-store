{
	"easycom": {
		"autoscan": true,
		"custom": {
			"^uni-(.*)": "@dcloudio/uni-ui/lib/uni-$1/uni-$1.vue",
			"^u-(.*)": "uview-plus/components/u-$1/u-$1.vue"
		}
	},
	"pages": [
		{
			"path": "pages/home/index",
			"style": {
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/search/index",
			"style": {
				"navigationBarTitleText": "Search",
				"navigationBarBackgroundColor": "#000000",
				"navigationBarTextStyle": "white"
			}
		},
		{
			"path": "pages/detail/index",
			"style": {
				"navigationBarTitleText": "",
				"navigationBarBackgroundColor": "#000000",
				"navigationBarTextStyle": "white"
			}
		},
		{
			"path": "pages/cart/index",
			"style": {
				"navigationBarTitleText": "Cart",
				"navigationBarBackgroundColor": "#000000",
				"navigationBarTextStyle": "white"
			}
		},
		{
			"path": "pages/my/index",
			"style": {
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/login/index",
			"style": {
				"navigationBarTitleText": "Login",
				"navigationBarBackgroundColor": "#000000",
				"navigationBarTextStyle": "white"
			}
		},
		{
			"path": "pages/address/index",
			"style": {
				"navigationBarTitleText": "Address",
				"navigationBarBackgroundColor": "#000000",
				"navigationBarTextStyle": "white"
			}
		},
		{
			"path": "pages/address/edit",
			"style": {
				"navigationBarTitleText": "Edit Address",
				"navigationBarBackgroundColor": "#000000",
				"navigationBarTextStyle": "white"
			}
		},
		{
			"path": "pages/order/confirm",
			"style": {
				"navigationBarTitleText": "Confirm Order",
				"navigationBarBackgroundColor": "#000000",
				"navigationBarTextStyle": "white"
			}
		},
		{
			"path": "pages/order/index",
			"style": {
				"navigationBarTitleText": "Orders",
				"navigationBarBackgroundColor": "#000000",
				"navigationBarTextStyle": "white"
			}
		},
		{
			"path": "pages/order/detail",
			"style": {
				"navigationBarTitleText": "Order Detail",
				"navigationBarBackgroundColor": "#000000",
				"navigationBarTextStyle": "white"
			}
